# Cloudflare R2 — Media Storage
# 1. Cloudflare dashboard > R2 > Create bucket
# 2. R2 > Manage R2 API tokens > Create token (Object Read & Write)
# 3. Enable public access on bucket OR set a custom domain
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
# Public bucket URL (from R2 bucket > Settings > Public access)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ashram_db"

# Server
PORT=3001
NODE_ENV=development

ALLOWED_ORIGINS=['http://localhost:5173']